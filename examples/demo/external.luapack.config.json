{
	"schemaVersion": 2,
	"entry": "./src/entries/external.lua",
	"output": "../../dist/demo_external_bundle.lua",
	"bundle": {
		"fallback": "external-only"
	},
	"modules": {
		"roots": ["./src", "./external_modules"],
		"missing": "warn",
		"rules": {
			"dkjson": {
				"mode": "bundle",
				"path": "./external_modules/dkjson",
				"recursive": false
			}
		}
	}
}
