{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "LuaPack v2 Configuration",
	"type": "object",
	"additionalProperties": false,
	"required": ["schemaVersion", "entry"],
	"properties": {
		"$schema": {
			"type": "string",
			"description": "Optional JSON Schema URI for editor integration."
		},
		"schemaVersion": {
			"type": "integer",
			"const": 2,
			"description": "Identifies the canonical LuaPack v2 configuration shape.",
			"default": 2
		},
		"entry": {
			"type": "string",
			"description": "Path to the entry Lua file that kicks off dependency analysis."
		},
		"output": {
			"type": "string",
			"description": "Optional destination path for the generated bundle. When omitted, LuaPack should emit '<entry-name>_packed.lua' alongside the entry file."
		},
		"missing": {
			"type": "string",
			"description": "Policy for unresolved static dependencies.",
			"enum": ["error", "warn", "ignore"],
			"default": "error"
		},
		"packages": {
			"type": "object",
			"description": "Declared package scopes keyed by Lua require prefix.",
			"propertyNames": {
				"type": "string",
				"pattern": "^[\\w\\.-]+$"
			},
			"additionalProperties": {
				"$ref": "#/definitions/packageConfig"
			},
			"default": {}
		},
		"bundle": {
			"type": "object",
			"description": "Defines the generated artifact contract.",
			"additionalProperties": false,
			"properties": {
				"fallback": {
					"type": "string",
					"description": "Runtime fallback policy when a module is not bundled.",
					"enum": ["never", "external-only", "always"],
					"default": "external-only"
				}
			},
			"default": {
				"fallback": "external-only"
			}
		}
	},
	"definitions": {
		"dependencyPolicy": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"mode": {
					"type": "string",
					"description": "How a package dependency should be handled.",
					"enum": ["bundle", "external", "ignore"],
					"default": "bundle"
				},
				"recursive": {
					"type": "boolean",
					"description": "When false, do not traverse into dependencies of this package.",
					"default": true
				}
			},
			"required": ["mode"],
			"default": {}
		},
		"moduleRule": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"mode": {
					"type": "string",
					"description": "Per-module bundling policy.",
					"enum": ["bundle", "external", "ignore"],
					"default": "bundle"
				},
				"path": {
					"type": "string",
					"description": "Optional explicit path to use instead of the default resolver result."
				},
				"recursive": {
					"type": "boolean",
					"description": "When false, skip dependency analysis for this module after it is resolved.",
					"default": true
				}
			},
			"required": ["mode"],
			"default": {}
		},
		"packageConfig": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"root": {
					"type": "string",
					"description": "Root directory for modules owned by this package."
				},
				"dependencies": {
					"type": "object",
					"description": "Dependency policy for declared package dependencies.",
					"propertyNames": {
						"type": "string",
						"pattern": "^[\\w\\.-]+$"
					},
					"additionalProperties": {
						"$ref": "#/definitions/dependencyPolicy"
					},
					"default": {}
				},
				"rules": {
					"type": "object",
					"description": "Local module rules scoped to this package.",
					"propertyNames": {
						"type": "string",
						"pattern": "^[\\w\\.\\-/]+$"
					},
					"additionalProperties": {
						"$ref": "#/definitions/moduleRule"
					},
					"default": {}
				}
			},
			"required": ["root"],
			"default": {}
		}
	}
}
